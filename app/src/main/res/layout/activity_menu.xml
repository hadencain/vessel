<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050508"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="56dp"
        android:paddingBottom="32dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VESSEL"
            android:textColor="#C8FFE8"
            android:textSize="48sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.3"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="import · enter"
            android:textColor="#446655"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:layout_marginBottom="40dp" />

        <!-- Import Video -->
        <Button
            android:id="@+id/btn_import_video"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="IMPORT VIDEO"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:backgroundTint="#0D2018"
            android:textColor="#40FF90"
            android:layout_marginBottom="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#1A4030"
            app:strokeWidth="1dp" />

        <TextView
            android:id="@+id/label_video_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="no video loaded"
            android:textColor="#2A4035"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="36dp" />

        <ProgressBar
            android:id="@+id/progress_import"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:indeterminateTint="#40FF90" />

        <!-- Toggles -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView style="@style/ParamLabel"
                android:text="IDLE SOUND"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="0dp" />
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_idle_sound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:thumbTint="#40FF90"
                app:trackTint="#1A4030" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="48dp">
            <TextView style="@style/ParamLabel"
                android:text="BLEED MODE"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="0dp" />
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_bleed_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                app:thumbTint="#40FF90"
                app:trackTint="#1A4030" />
        </LinearLayout>

        <!-- Enter AR -->
        <Button
            android:id="@+id/btn_enter_ar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="ENTER AR"
            android:fontFamily="monospace"
            android:letterSpacing="0.25"
            android:textSize="16sp"
            android:enabled="false"
            android:backgroundTint="#0A3020"
            android:textColor="#80FFCC"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#204030"
            app:strokeWidth="1dp" />

    </LinearLayout>
</ScrollView>
